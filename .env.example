# === LLM (Секретарь, Юрист) ===
LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# GIGACHAT_CREDENTIALS=
# GIGACHAT_SCOPE=GIGACHAT_API_PERS
# GIGACHAT_MODEL=GigaChat

# === Эмбеддинги (Юрист, RAG) ===
EMBEDDING_PROVIDER=local
# EMBEDDING_PROVIDER=openai
# OPENAI_API_KEY=
# OPENAI_EMBEDDING_MODEL=text-embedding-ada-002
# Эксперимент: эмбеддинги GigaChat (нужен GIGACHAT_CREDENTIALS; после смены — очистить индекс и загрузить документы заново)
# EMBEDDING_PROVIDER=gigachat
# GIGACHAT_EMBEDDING_MODEL=Embeddings
# GIGACHAT_EMBEDDING_MODEL=EmbeddingsGigaR
# GIGACHAT_MAX_EMBED_CHARS=950
# LOCAL_EMBEDDING_MODEL=models/paraphrase-multilingual-MiniLM-L12-v2
# EMBEDDING_LOCAL_FILES_ONLY=1
# EMBED_BATCH_SIZE=16
# HF_ENDPOINT=https://hf-mirror.com
# HF_HUB_DOWNLOAD_TIMEOUT=300

# === Whisper (Секретарь) — на VPS быстрее base + beam 1, чем small + beam 5 ===
WHISPER_MODEL_SIZE=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_BEAM_SIZE=1
# WHISPER_CPU_THREADS=0
# WHISPER_VAD_FILTER=true
# WHISPER_CONDITION_ON_PREVIOUS=false
# WHISPER_PRELOAD=true
# WHISPER_LOG_EVERY_N_SEGMENTS=15
# tiny — ещё быстрее, но хуже качество; cuda + float16 — при наличии GPU

# === Экономист ===
ECONOMIST_FACT_SHEET_URL=https://docs.google.com/spreadsheets/d/ВАШ_ID/edit
N8N_ECONOMIST_WEBHOOK_URL=https://ваш-n8n.example/webhook/economist
N8N_ECONOMIST_TIMEOUT=120

# === Юрист ===
LAWYER_CITATION_LLM_REPAIR=true
# RAG: чанки и векторный поиск (после смены LAWYER_CHUNK_* — очистить индекс и загрузить документы заново)
# LAWYER_CHUNK_SIZE=1200
# LAWYER_CHUNK_OVERLAP=200
# LAWYER_RETRIEVE_K=80
# LAWYER_CONTEXT_K=8
# LAWYER_SEMANTIC_WEIGHT=0.45
# LAWYER_SEMANTIC_MIN_SCORE=0.42
# LAWYER_SEMANTIC_TOP_K=6
# LAWYER_BALANCE_FILES=false
# LAWYER_LLM_QUERY_REWRITE=true
# LAWYER_CONTEXT_MERGE_NEIGHBORS=1
# MAX_LAWYER_CITATION_CHARS=2500
# MAX_LAWYER_LLM_CONTEXT_CHARS=28000
# MAX_LAWYER_PAGES=200
# OCR сканов на VPS (при «Killed» в логе):
# LAWYER_OCR_SCALE=1.0
# LAWYER_OCR_MAX_SIDE=1200
# LAWYER_OCR_MAX_PAGES=8
# LAWYER_OCR_PAGE_TIMEOUT_SEC=180
# LAWYER_OCR_SUBPROCESS=true

# === Лимиты загрузки (байты) ===
# MAX_DOCUMENT_SIZE=52428800
# MAX_AUDIO_SIZE=104857600
# MAX_EXCEL_SIZE=20971520

# === Прочее ===
# APP_TIMEZONE=Europe/Moscow
# CHROMA_PERSIST_DIR=chroma_data
# HISTORY_SIZE=5
# LOGO_SOURCE=static/img/logo.png
# FAVICON_SOURCE=static/img/favicon.png
